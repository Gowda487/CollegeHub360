{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "Student profile and overall status",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "name": { "type": "string" },
        "course": { "type": "string" },
        "gpa": { "type": "number" },
        "attendanceRate": { "type": "number" },
        "totalClasses": { "type": "number" },
        "attendedClasses": { "type": "number" },
        "email": { "type": "string" }
      },
      "required": ["studentId", "name", "course"]
    },
    "Mark": {
      "title": "Mark",
      "description": "Semester marks for a student",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "semester": { "type": "string" },
        "subjects": {
          "type": "array",
          "description": "List of subject scores",
          "items": {
            "type": "object",
            "properties": {
              "subject": { "type": "string" },
              "score": { "type": "number" },
              "max": { "type": "number" }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "AttendanceRecord": {
      "title": "Attendance Record",
      "description": "A single attendance entry",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "name": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["present", "late", "absent"] },
        "location": { "type": "string" }
      }
    },
    "User": {
      "title": "User",
      "description": "App user roles and permissions",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "student"] },
        "studentId": { "type": "string", "description": "Linked student profile for student role" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User roles and settings"
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "All student profiles"
    },
    "/marks/{markId}": {
      "schema": "Mark",
      "description": "Academic records"
    },
    "/attendance/{attendanceId}": {
      "schema": "AttendanceRecord",
      "description": "Daily attendance logs"
    }
  }
}
