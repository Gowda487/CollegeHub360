rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic Deny-All
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 64; }
    
    // Users
    match /users/{userId} {
      allow read: if true; // Allow public read so we can check if an admin exists
      allow write: if isSignedIn();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if true;
    }

    // Students
    match /students/{studentId} {
      allow read: if true; // Allow public read for demo
      allow write: if true; // Allow public write for demo
    }

    // Attendance
    match /attendance/{attendanceId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // Marks
    match /marks/{markId} {
      allow read: if true;
      allow write: if true;
    }

    // Connection Test
    match /test/connection {
      allow read: if true;
    }
  }
}
